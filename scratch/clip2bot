#!/usr/bin/env python3
''''which python3 >/dev/null 2>&1 && exec "$(dirname "$0")/../venv/bin/python3" "$0" "$@" # '''
# --- PORTABLE VENV WRAPPER ---

import os
import sys
import subprocess
import pyperclip

MAX_TRUNCATE_SIZE = 1024 * 1024  # 1MB limit per file

def get_tracked_files(include_untracked=False):
    """Identifies workspace files using high-speed git indexing descriptors."""
    cmd = ["git", "ls-files", "--cached"]
    if include_untracked:
        # Pull in untracked workspace assets while safely honoring .gitignore boundaries
        cmd.append("--others")
        cmd.append("--exclude-standard")
        
    result = subprocess.run(cmd, capture_output=True, text=True)
    return set(result.stdout.splitlines())

def read_file(file_path):
    """Reads and formats a file for the clipboard bundle."""
    try:
        size = os.path.getsize(file_path)
        with open(file_path, 'r', errors='ignore') as f:
            content = f.read(MAX_TRUNCATE_SIZE)
            header = f"\n--- BEGIN FILE: {file_path} | Size: {size} bytes ---\n"
            return f"{header}{content}"
    except Exception as e:
        return f"\n[!] Error reading {file_path}: {e}"

def process_path(target, include_untracked=False):
    """Recursively processes target elements bounded by git exclusion safety rules."""
    output = []
    allowed_files = get_tracked_files(include_untracked)

    if os.path.isdir(target):
        for root, _, files in os.walk(target):
            for file in files:
                full_path = os.path.join(root, file)
                # Normalize relative directory structures to match git index string formats
                rel_path = os.path.relpath(full_path, start=os.getcwd())
                normalized_path = os.path.normpath(rel_path).replace('\\', '/')
                
                if normalized_path in allowed_files or full_path in allowed_files:
                    output.append(read_file(full_path))
    else:
        normalized_target = os.path.normpath(target).replace('\\', '/')
        if normalized_target in allowed_files or target in allowed_files:
            output.append(read_file(target))
        else:
            return f"[!] Path '{target}' is omitted by project configuration laws."
        
    return "\n".join(output)

def main():
    # Dynamic Flag Interception Loop
    include_all = False
    if "--everything" in sys.argv:
        include_all = True
        sys.argv.remove("--everything")
        
    target = sys.argv[1] if len(sys.argv) > 1 else "."
    
    if not os.path.exists(target):
        print(f"[!] Error: Target path '{target}' does not exist on disk.")
        sys.exit(1)
        
    content = process_path(target, include_untracked=include_all)
    char_count = len(content)
    print(f"[+] Bundle generated: {char_count} characters.")
    
    try:
        pyperclip.copy(content)
        print("[+] Successfully copied workspace layout state to the clipboard.")
    except Exception as e:
        print(f"[!] Clipboard interface fault encountered: {e}")

if __name__ == "__main__":
    main()
