import os
import sys
import argparse
import subprocess
from pathlib import Path

# Try importing your local helper; fall back to a basic import if needed
try:
    import clip_helper
except ImportError:
    sys.path.append(str(Path(__file__).resolve().parent))
    import clip_helper

def is_ignored_by_git(path: Path) -> bool:
    """Checks if Git is actively ignoring a path."""
    try:
        res = subprocess.run(
            ["git", "check-ignore", "-q", str(path)],
            capture_output=True
        )
        return res.returncode == 0
    except Exception:
        return False

def main():
    parser = argparse.ArgumentParser(description="Bundle local files to host clipboard.")
    parser.add_argument("targets", nargs="*", help="File or folder targets to copy")
    parser.add_argument("--everything", "--everythin", action="store_true", help="Force copy ignored files")
    args = parser.parse_args()

    resolved_files = []

    if not args.targets:
        print("[X] Abort: No target files specified.")
        sys.exit(1)

    for target_str in args.targets:
        target_path = Path(target_str).resolve()
        
        if not target_path.exists():
            print(f"[!] Warning: Target does not exist on disk: {target_str}")
            continue

        if target_path.is_file():
            # CORE FIX: If explicitly requested, skip git-ignore validation unless strictly forbidden
            if args.everything or not is_ignored_by_git(target_path):
                resolved_files.append(target_path)
            else:
                # Let user know we are bypassing the ignore boundary because they asked for it explicitly
                print(f"[*] Path is ignored by Git, but explicitly requested. Reading directly: {target_path.name}")
                resolved_files.append(target_path)
        elif target_path.is_dir():
            # For directories, default to non-ignored files unless --everything is passed
            for p in target_path.rglob("*"):
                if p.is_file():
                    if args.everything or not is_ignored_by_git(p):
                        resolved_files.append(p)

    if not resolved_files:
        print("[X] Abort: No valid files identified or allowed under index tracking guidelines.")
        sys.exit(1)

    # Build the transfer bundle using UTF-8 to prevent CP1252 translation corruptions
    bundle_content = ""
    for path in resolved_files:
        try:
            content = path.read_text(encoding="utf-8")
            bundle_content += f"--- BEGIN FILE: {path.relative_to(Path.cwd())} ---\n"
            bundle_content += content
            bundle_content += f"\n--- END FILE: {path.relative_to(Path.cwd())} ---\n\n"
        except Exception as e:
            print(f"[!] Error reading {path.name}: {e}")

    if bundle_content:
        clip_helper.set_host_clipboard(bundle_content)
        print(f"[+] Bundle generated successfully ({len(resolved_files)} assets | {len(bundle_content)} characters). Pushed to clipboard.")
    else:
        print("[X] Abort: Compiled bundle content is empty.")
        sys.exit(1)

if __name__ == "__main__":
    main()
