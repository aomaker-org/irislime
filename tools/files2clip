import os
import sys
import glob
import subprocess
import hashlib
import argparse

MAX_TRUNCATE_SIZE = 1024 * 1024  # 1MB safety gate
MAX_CLIPBOARD_BYTES = 250 * 1024 # 250 KB safety ceiling to prevent browser freezes

def get_tracked_files(include_untracked=False):
    """Parses the git index to enforce out-of-tree and workspace asset tracking."""
    try:
        cmd = ["git", "ls-files", "--cached"]
        if include_untracked:
            cmd.extend(["--others", "--exclude-standard"])
        result = subprocess.run(cmd, capture_output=True, text=True, check=True)
        return set(result.stdout.splitlines())
    except subprocess.CalledProcessError:
        return None

def generate_file_stream(file_path):
    """Wraps target text asset contents into symmetrical, tail-scrolling blocks."""
    try:
        size = os.path.getsize(file_path)
        with open(file_path, 'r', errors='ignore') as f:
            content = f.read(MAX_TRUNCATE_SIZE)
        
        clean_content = content.replace('\r\n', '\n')
        sha256 = hashlib.sha256(clean_content.encode('utf-8')).hexdigest()
        
        header = f"--- BEGIN FILE: {file_path} | Size: {size} bytes | SHA256: {sha256} ---\n"
        footer = f"\n--- END FILE: {file_path} ---\n"
        return f"{header}{clean_content}{footer}"
    except Exception as e:
        return f"\n[!] Error generating stream node for {file_path}: {e}\n"

def resolve_targets(targets, include_untracked=False):
    """Resolves arbitrary targets, directories, and wildcards against the Git index."""
    allowed_files = get_tracked_files(include_untracked)
    resolved_files = []

    for target in targets:
        # Resolve user home directory tilde paths (~/.bashrc -> /home/fekerr/.bashrc)
        expanded_target = os.path.expanduser(target)
        globbed = glob.glob(expanded_target, recursive=True)
        
        if not globbed:
            if not os.path.exists(expanded_target):
                print(f"[!] Warning: Target '{target}' matched no files or paths.", file=sys.stderr)
            continue

        for path in globbed:
            norm_path = os.path.normpath(path).replace('\\', '/')
            
            if os.path.isdir(path):
                # DIRECTORY: Aggressively restrict walks to git-tracked assets
                for root, _, files in os.walk(path):
                    for file in files:
                        full_path = os.path.join(root, file)
                        rel_path = os.path.relpath(full_path, start=os.getcwd())
                        rel_norm = os.path.normpath(rel_path).replace('\\', '/')
                        if allowed_files is None or rel_norm in allowed_files:
                            resolved_files.append(full_path)
            else:
                # FILE: Check if the user named this specific file target directly on the CLI
                rel_path = os.path.relpath(path, start=os.getcwd())
                rel_norm = os.path.normpath(rel_path).replace('\\', '/')
                
                # Check if this file was explicitly passed as an input parameter
                is_explicit_target = any(
                    os.path.normpath(os.path.expanduser(t)) == os.path.normpath(path) 
                    for t in targets
                )
                
                # Allow if: explicitly targeted, git-tracked, or git validation isn't available
                if is_explicit_target or (allowed_files is None) or (rel_norm in allowed_files) or (norm_path in allowed_files):
                    resolved_files.append(path)

    return list(dict.fromkeys(resolved_files))

def main():
    parser = argparse.ArgumentParser(
        description="Pack specific workspace targets into the clipboard container."
    )
    parser.add_argument(
        "targets", nargs="*", default=["."],
        help="Target files, directories, or wildcard patterns"
    )
    parser.add_argument(
        "--everything", action="store_true",
        help="Include untracked workspace files matching standard git exclusions."
    )
    
    args = parser.parse_args()
    files_to_pack = resolve_targets(args.targets, include_untracked=args.everything)
    
    if not files_to_pack:
        print("[X] Abort: No valid files identified or allowed under index tracking guidelines.", file=sys.stderr)
        sys.exit(1)
        
    output_nodes = [generate_file_stream(f) for f in files_to_pack]
    content = "".join(output_nodes)
    
    timestamp = subprocess.run(["date", "+%Y%m%d_%H%M%S"], capture_output=True, text=True).stdout.strip()
    wrapped_stream = (
        f"# Stream Frame: {timestamp}_Workspace_Context_Payload\n"
        f"* **Target Scope Count:** {len(files_to_pack)} resolved files\n"
        f"-------------\n\n"
        f"{content}\n"
        f"-------------\n"
        f"# Tracking Footer: {timestamp}_Workspace_Context_Payload_Complete\n"
    )
    
    # --------------------------------------------------------------------------
    # CLIPBOARD OVERFLOW EVALUATION
    # --------------------------------------------------------------------------
    payload_bytes = len(wrapped_stream.encode('utf-8', errors='ignore'))
    
    if payload_bytes > MAX_CLIPBOARD_BYTES:
        scratch_dir = os.path.join(os.getcwd(), "scratch")
        os.makedirs(scratch_dir, exist_ok=True)
        
        # Prevent collisions down to the second
        base_name = f"bundle_{timestamp}"
        target_file = os.path.join(scratch_dir, f"{base_name}.txt")
        counter = 1
        while os.path.exists(target_file):
            target_file = os.path.join(scratch_dir, f"{base_name}_{counter}.txt")
            counter += 1
            
        # Safely archive the full payload to disk
        try:
            with open(target_file, 'w', encoding='utf-8') as f:
                f.write(wrapped_stream)
            
            # Generate the lightweight pointer for the clipboard
            wrapped_stream = (
                f"=== CLIPBOARD OVERFLOW PROTECTION ===\n"
                f"Status: Safety Threshold Exceeded ({MAX_CLIPBOARD_BYTES / 1024:.1f} KB)\n"
                f"Total Target Assets Combined: {len(files_to_pack)}\n"
                f"Unpacked Payload Size: {payload_bytes / 1024:.2f} KB\n"
                f"Written to Local Storage: {os.path.abspath(target_file)}\n"
                f"=====================================\n"
            )
            print(f"[!] OVERFLOW WARNING: Payload size ({payload_bytes / 1024:.2f} KB) exceeds safety limit!", file=sys.stderr)
            print(f"    --> Full structural log written to: {target_file}", file=sys.stderr)
        except Exception as e:
            print(f"[X] Write Error: Failed to archive overflow bundle to disk: {e}", file=sys.stderr)
            sys.exit(1)

    # --------------------------------------------------------------------------
    # SYSTEM CLIPBOARD EXECUTION FLOW
    # --------------------------------------------------------------------------
    copied = False
    
    # Try the absolute WSL-to-Windows clipboard pipe first
    wsl_clip = "/mnt/c/Windows/System32/clip.exe"
    if os.path.exists(wsl_clip):
        try:
            proc = subprocess.Popen([wsl_clip], stdin=subprocess.PIPE, text=True, errors='ignore')
            proc.communicate(input=wrapped_stream)
            if proc.returncode == 0:
                copied = True
        except Exception as e:
            print(f"[-] Diagnostic: WSL absolute clip.exe path failed: {e}", file=sys.stderr)

    # Fall back to raw command check (for Windows environments where clip.exe is native in PATH)
    if not copied:
        try:
            proc = subprocess.Popen(['clip.exe'], stdin=subprocess.PIPE, text=True, errors='ignore')
            proc.communicate(input=wrapped_stream)
            if proc.returncode == 0:
                copied = True
        except Exception:
            pass

    # Fall back to Linux system clipboards ONLY if not running on WSL/Windows paths
    if not copied:
        for cmd in [['xclip', '-selection', 'clipboard'], ['wl-copy']]:
            try:
                proc = subprocess.Popen(cmd, stdin=subprocess.PIPE, text=True)
                proc.communicate(input=wrapped_stream)
                if proc.returncode == 0:
                    copied = True
                    break
            except Exception:
                continue

    if copied:
        if payload_bytes > MAX_CLIPBOARD_BYTES:
            print(f"[+] Protection Active: Summary pointer loaded into clipboard.")
        else:
            print(f"[+] Bundle generated successfully ({len(files_to_pack)} assets). Pushed to clipboard.")
    else:
        print("[X] System Routing Fault: Clipboard sub-system could not be accessed natively.", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
