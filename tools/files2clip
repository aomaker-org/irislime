import os
import sys
import glob
import subprocess
import pyperclip
import hashlib
import argparse

MAX_TRUNCATE_SIZE = 1024 * 1024  # 1MB safety gate

def get_tracked_files(include_untracked=False):
    """Parses the git index to enforce out-of-tree and workspace asset tracking."""
    try:
        cmd = ["git", "ls-files", "--cached"]
        if include_untracked:
            cmd.extend(["--others", "--exclude-standard"])
        result = subprocess.run(cmd, capture_output=True, text=True, check=True)
        return set(result.stdout.splitlines())
    except subprocess.CalledProcessError:
        # Fallback if executed outside a git repository boundary during testing
        return None

def generate_file_stream(file_path):
    """Wraps target text asset contents into symmetrical, tail-scrolling blocks."""
    try:
        size = os.path.getsize(file_path)
        with open(file_path, 'r', errors='ignore') as f:
            content = f.read(MAX_TRUNCATE_SIZE)
        
        clean_content = content.replace('\r\n', '\n')
        sha256 = hashlib.sha256(clean_content.encode('utf-8')).hexdigest()
        
        header = f"--- BEGIN FILE: {file_path} | Size: {size} bytes | SHA256: {sha256} ---\n"
        footer = f"\n--- END FILE: {file_path} ---\n"
        return f"{header}{clean_content}{footer}"
    except Exception as e:
        return f"\n[!] Error generating stream node for {file_path}: {e}\n"

def resolve_targets(targets, include_untracked=False):
    """Resolves arbitrary targets, directories, and wildcards against the Git index."""
    allowed_files = get_tracked_files(include_untracked)
    resolved_files = []

    for target in targets:
        # Process wildcard globs explicitly (recursive support enabled)
        globbed = glob.glob(target, recursive=True)
        if not globbed:
            # If glob resolves nothing, check if it's a direct missing file literal
            if not os.path.exists(target):
                print(f"[!] Warning: Target '{target}' matched no files or paths.")
            continue

        for path in globbed:
            norm_path = os.path.normpath(path).replace('\\', '/')
            
            if os.path.isdir(path):
                for root, _, files in os.walk(path):
                    for file in files:
                        full_path = os.path.join(root, file)
                        rel_path = os.path.relpath(full_path, start=os.getcwd())
                        rel_norm = os.path.normpath(rel_path).replace('\\', '/')
                        if allowed_files is None or rel_norm in allowed_files:
                            resolved_files.append(full_path)
            else:
                rel_path = os.path.relpath(path, start=os.getcwd())
                rel_norm = os.path.normpath(rel_path).replace('\\', '/')
                if allowed_files is None or rel_norm in allowed_files or norm_path in allowed_files:
                    resolved_files.append(path)

    # De-duplicate while preserving order
    return list(dict.fromkeys(resolved_files))

def main():
    parser = argparse.ArgumentParser(
        description="Pack specific workspace targets and wildcards cleanly into the clipboard container."
    )
    parser.add_argument(
        "targets", nargs="*", default=["."],
        help="Target files, directories, or wildcard patterns (e.g., infra/make/*.mk)"
    )
    parser.add_argument(
        "--everything", action="store_true",
        help="Include untracked workspace files matching standard git exclusions."
    )
    
    args = parser.parse_args()
    
    # Resolve global list array
    files_to_pack = resolve_targets(args.targets, include_untracked=args.everything)
    
    if not files_to_pack:
        print("[X] Abort: No valid files identified or allowed under index tracking guidelines.")
        sys.exit(1)
        
    output_nodes = [generate_file_stream(f) for f in files_to_pack]
    content = "".join(output_nodes)
    
    timestamp = subprocess.run(["date", "+%Y%m%d_%H%M%S"], capture_output=True, text=True).stdout.strip()
    wrapped_stream = (
        f"# Stream Frame: {timestamp}_Workspace_Context_Payload\n"
        f"* **Target Scope Count:** {len(files_to_pack)} resolved files\n"
        f"-------------\n\n"
        f"{content}\n"
        f"-------------\n"
        f"# Tracking Footer: {timestamp}_Workspace_Context_Payload_Complete\n"
    )
    
    pyperclip.copy(wrapped_stream)
    print(f"[+] Bundle generated successfully ({len(files_to_pack)} assets | {len(wrapped_stream)} characters). Pushed to clipboard.")

if __name__ == "__main__":
    main()

