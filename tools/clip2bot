#!/bin/sh
''''which python3 >/dev/null 2>&1 && exec "$(dirname "$0")/../venv/bin/python3" "$0" "$@" # '''
# --- PORTABLE VENV WRAPPER ---
# This wrapper finds the project's venv relative to the script location.
# It is invisible to the Python interpreter below.

import os
import sys
import subprocess
import pyperclip

MAX_TRUNCATE_SIZE = 1024 * 1024  # 1MB limit per file

def get_tracked_files():
    """Uses Git to quickly identify all files we should care about."""
    result = subprocess.run(
        ["git", "ls-files"],
        capture_output=True, text=True
    )
    # Return a set of paths for O(1) lookup
    return set(result.stdout.splitlines())

def read_file(file_path):
    """Reads and formats a file for the clipboard/LLM."""
    try:
        size = os.path.getsize(file_path)
        with open(file_path, 'r', errors='ignore') as f:
            content = f.read(MAX_TRUNCATE_SIZE)
            header = f"\n--- BEGIN FILE: {file_path} | Size: {size} bytes ---\n"
            return f"{header}{content}"
    except Exception as e:
        return f"\n[!] Error reading {file_path}: {e}"

def process_path(target):
    """Recursively processes a file or directory using Git tracking."""
    output = []
    tracked = get_tracked_files()

    if os.path.isdir(target):
        for root, _, files in os.walk(target):
            for file in files:
                full_path = os.path.join(root, file)
                # Normalize path to match git-ls-files output
                normalized_path = os.path.normpath(full_path)
                
                if normalized_path in tracked:
                    output.append(read_file(full_path))
    else:
        # If user targeted a specific file, check if it's tracked
        if os.path.normpath(target) in tracked:
            output.append(read_file(target))
        else:
            return f"[!] Path '{target}' is not tracked by Git or is ignored."
        
    return "\n".join(output)

def main():
    target = sys.argv[1] if len(sys.argv) > 1 else "."
    
    if not os.path.exists(target):
        print(f"[!] Error: {target} does not exist.")
        sys.exit(1)
        
    content = process_path(target)
    
    # Context Health Check
    char_count = len(content)
    print(f"[+] Bundle generated: {char_count} characters.")
    
    try:
        pyperclip.copy(content)
        print("[+] Successfully copied to clipboard.")
    except Exception as e:
        print(f"[!] Clipboard error (possible size limit): {e}")

if __name__ == "__main__":
    main()
