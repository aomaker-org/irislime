#!/bin/sh
''''which python3 >/dev/null 2>&1 && exec "$(dirname "$0")/../venv/bin/python3" "$0" "$@" # '''
# --- PORTABLE VENV WRAPPER ---
# This wrapper finds the project's venv relative to the script location.
# It is invisible to the Python interpreter below.

import os
import sys
import subprocess
import pyperclip

MAX_TRUNCATE_SIZE = 1024 * 1024  # 1MB limit per file

def get_tracked_files():
    """Uses Git to identify all tracked files, normalizing them to absolute paths

    to guarantee cross-directory execution safety.
    """
    try:
        # Determine the definitive root of the repository tracking branch
        repo_root = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, check=True
        ).stdout.strip()
        
        # Force paths to output relative to project top directory (--full-name)
        result = subprocess.run(
            ["git", "ls-files", "--full-name"],
            capture_output=True, text=True, check=True
        )
        
        # Build an absolute path tracking set for definitive O(1) cross-referencing
        return {os.path.normpath(os.path.join(repo_root, line)) for line in result.stdout.splitlines()}
    except subprocess.CalledProcessError as e:
        print(f"[!] Git Error: Unable to determine repository architecture. Verification failed: {e}")
        sys.exit(1)

def read_file(file_path):
    """Reads and formats a file for the clipboard/LLM context window."""
    try:
        size = os.path.getsize(file_path)
        with open(file_path, 'r', errors='ignore') as f:
            content = f.read(MAX_TRUNCATE_SIZE)
            
            # Explicit warning within context if file is hard-truncated
            truncation_flag = ""
            if size > MAX_TRUNCATE_SIZE:
                truncation_flag = f" | [WARNING: CONTENT TRUNCATED AT {MAX_TRUNCATE_SIZE} BYTES]"
                
            header = f"\n--- BEGIN FILE: {file_path} | Size: {size} bytes{truncation_flag} ---\n"
            return f"{header}{content}"
    except Exception as e:
        return f"\n[!] Error reading structural path {file_path}: {e}"

def process_path(target):
    """Recursively processes a file or directory utilizing absolute path validation."""
    output = []
    tracked = get_tracked_files()
    
    # Absolute resolution of target to guarantee uniform string matching
    abs_target = os.path.normpath(os.path.abspath(target))

    if os.path.isdir(abs_target):
        for root, _, files in os.walk(abs_target):
            for file in files:
                full_path = os.path.join(root, file)
                abs_file_path = os.path.normpath(os.path.abspath(full_path))
                
                if abs_file_path in tracked:
                    output.append(read_file(abs_file_path))
    else:
        if abs_target in tracked:
            output.append(read_file(abs_target))
        else:
            return f"[!] Path '{target}' is not explicitly tracked by Git or is actively ignored."
        
    return "\n".join(output)

def main():
    target = sys.argv[1] if len(sys.argv) > 1 else "."
    
    if not os.path.exists(target):
        print(f"[!] Error: Target path '{target}' does not exist on filesystem.")
        sys.exit(1)
        
    content = process_path(target)
    
    if not content or content.startswith("[!]"):
        print(content)
        sys.exit(1)
        
    char_count = len(content)
    print(f"[+] Bundle compiled: {char_count} characters.")
    
    try:
        pyperclip.copy(content)
        print("[+] Content successfully staged to the host clipboard.")
    except Exception as e:
        print(f"[!] Clipboard operational failure: {e}")
        print("[*] Architecture Note: Headless or WSL environment detected. If clipboard utilities ")
        print("    are missing, pipe command output directly via standard output hooks.")

if __name__ == "__main__":
    main()
