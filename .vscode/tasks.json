{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "🔨 BUILD OPENVINO BACKEND",
            "type": "shell",
            "command": "./tools/build_openvino.sh",
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            }
        },
        {
            "label": "🧪 RUN MULTICAP (PY)",
            "type": "shell",
            "command": "python3 ./tools/multicap_runner.py",
            "problemMatcher": [],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            }
        },
        {
            "label": "🩺 OPENVINO HEALTHCHECK",
            "type": "shell",
            "command": "./tools/openvino_healthcheck.sh",
            "problemMatcher": [],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            }
        }
    ]
}
