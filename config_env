#!/bin/bash
# config_env - Idempotent environment loader
# Usage: source config_env [unset|force]

# 1. Guard: Prevent execution as a sub-shell
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    echo "[!] ERROR: You must SOURCE this file, not execute it."
    return 1
fi

# 2. Handle explicit unset
if [ "$1" == "unset" ]; then
    echo "[!] Unsetting IrisLime environment..."
    unset IRISLIME_READY
    unset ONEAPI_ROOT
    unset MKLROOT
    
    if command -v deactivate &> /dev/null; then
        deactivate
        echo "[+] Virtual environment deactivated."
    fi
    echo "[+] IrisLime environment unset."
    return 0
fi

# 3. Idempotency check with force override
if [ -n "$IRISLIME_READY" ] && [ "$1" != "force" ]; then
    echo "[!] IrisLime environment is already loaded. Use 'source config_env force' to reload."
    return 0
fi

# 4. Set Symbol Caching for GDB
export DEBUGINFOD_CACHE_PATH=/home/fekerr/.cache/gdb_symbols
mkdir -p "$DEBUGINFOD_CACHE_PATH"

# 5. Activate venv (Robustly)
if [ -f "venv/bin/activate" ]; then
    if [[ "$VIRTUAL_ENV" != "" ]]; then
        deactivate 2>/dev/null || unset VIRTUAL_ENV
    fi
    source venv/bin/activate
    echo "[+] Virtual environment activated."
else
    echo "[!] Virtual environment not found. Run 'make setup' first."
fi

# 6. Source Intel oneAPI
INTEL_ROOT="/opt/intel/oneapi"
if [ -f "$INTEL_ROOT/setvars.sh" ]; then
    source "$INTEL_ROOT/setvars.sh" --force > /dev/null
    export ONEAPI_ROOT="$INTEL_ROOT"
    export MKLROOT="$INTEL_ROOT/mkl/latest"
    echo "[+] Intel oneAPI environment sourced (Root: $ONEAPI_ROOT)."
else
    echo "[!] Intel oneAPI setvars.sh not found at $INTEL_ROOT."
fi

# 7. Set the marker
export IRISLIME_READY=1
echo "[+] IrisLime environment is ready."
