#!/usr/bin/env bash
# ==============================================================================
# Path:        config_env
# Purpose:     Idempotent WSL2 environment loader with volatile flag state
#              protection, dynamic parameter tagging, and prompt configuration.
# Target OS:   Ubuntu 26.04 LTS / WSL2 Subsystem ONLY
# Type:        Sourced Script (Execute via 'source config_env' or '. config_env')
# Lineage:     Unified Asset Specification
# Updated:     20260710_0135 (fekerr & Gemini / Forensic Logic Re-Alignment)
# ==============================================================================

# 1. Guard: Prevent direct subshell execution without killing the active terminal
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    echo "[!] ERROR: You must SOURCE this file, not execute it." >&2
    return 1 2>/dev/null || exit 1
fi

# 2. Intercept and Parse Input Parameters
LOCAL_TAG=""
if [ "${1:-}" == "force" ] || [ "${1:-}" == "--force" ]; then
    echo "[!] Force reload detected. Cycling environment state..."
    unset IRISLIME_READY
    LOCAL_TAG="${2:-}"
elif [ "${1:-}" == "unset" ]; then
    echo "[!] Unsetting IrisLime environment..."
    unset IRISLIME_READY
    unset IRISLIME_ROOT
    unset ONEAPI_ROOT
    unset MKLROOT
    unset ONEAPI_DEVICE_SELECTOR
    unset OpenVINO_DIR
    unset INTEL_OPENVINO_DIR
    unset ISLM_USER
    unset ISLM_RUN_TYPE
    unset IRISLIME_TEST_MODEL
    unset IRISLIME_MODELS_DIR
    unset ZES_ENABLE_SYSMAN
    unset DEBUGINFOD_CACHE_PATH
    unset TCM_ENABLE
    
    # Remove custom functions and aliases
    unset -f pto pti
    unalias files2clip clip2files pack2clip patch_incoming 2>/dev/null
    
    # Cleanly revert NVM configurations if registered
    if command -v nvm >/dev/null 2>&1; then
        nvm deactivate >/dev/null 2>&1 || true
        echo "[+] Node version manager tracking deactivated."
    fi
    
    if command -v deactivate >/dev/null 2>&1; then
        deactivate
        echo "[+] Virtual environment deactivated."
    fi
    echo "[+] IrisLime environment unset."
    return 0
elif [ -n "${1:-}" ]; then
    # First argument is treated directly as the prompt runtime tag
    LOCAL_TAG="$1"
fi

# 3. Process Runtime Tag Assertions & Parameter Suggestions
if [ -n "${LOCAL_TAG}" ]; then
    export ISLM_RUN_TYPE="${LOCAL_TAG}"
    echo "[+] Prompt run-type tag locked to: [${ISLM_RUN_TYPE}]"
elif [ -z "${ISLM_RUN_TYPE:-}" ]; then
    echo "[i] Tip: To tag your prompt context, try: export ISLM_RUN_TYPE=\"prompt sugar\""
    echo "    (Alternatively, pass it directly: '. config_env your_tag')"
else
    # Exception Gate: Retain the active prompt tag during a force cycle if a new one wasn't passed
    echo "[+] Retaining active prompt tag exception: [${ISLM_RUN_TYPE}]"
fi

# 4. Idempotency Check (Short-circuits safely if environment is already resident)
if [ -n "${IRISLIME_READY:-}" ]; then
    echo "[!] IrisLime environment is already loaded. Use 'source config_env force' to re-verify."
    return 0
fi

# 5. Activate Python Virtual Environment via uv Standard Layout (.venv)
export IRISLIME_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_PATH="${IRISLIME_ROOT}/.venv"
if [ -f "${VENV_PATH}/bin/activate" ]; then
    if [[ "${VIRTUAL_ENV:-}" != "" ]]; then
        deactivate >/dev/null 2>&1 || unset VIRTUAL_ENV
    fi
    source "${VENV_PATH}/bin/activate"
    echo "[+] Virtual environment activated (${VENV_PATH})."
    
    if command -v uv >/dev/null 2>&1; then
        echo "[*] Auditing and syncing local hardware runtimes with project lockfile..."
        uv sync
    fi
else
    echo "[!] Virtual environment folder not found at ${VENV_PATH}." >&2
    if command -v uv >/dev/null 2>&1; then
        echo "[*] Bootstrapping a fresh environment automatically via uv..."
        uv sync
        source "${VENV_PATH}/bin/activate"
    else
        echo "[!] Warning: 'uv' tool absent. Run 'pip install uv && uv sync' to provision toolchains." >&2
    fi
fi

# STATE GUARD: CAPTURE INITIAL INTERACTIVE TERMINAL SHELL FLAGS
#
# We record if nounset (-u) is currently active in the user's running shell 
# session memory block so we can restore it exactly as it was post-execution.

if [[ $- == *u* ]]; then _IR_ORIG_SET_U=1; else _IR_ORIG_SET_U=0; fi

# ------------------------------------------------------------------------------
# 6. Source Intel oneAPI Baseline Environment
# ------------------------------------------------------------------------------
INTEL_ROOT="/opt/intel/oneapi"
if [ -f "$INTEL_ROOT/setvars.sh" ]; then
    # Provision authoritative forensics log directory path
    mkdir -p logs
    INTEL_LOG="logs/intel_setvars.log"
    echo "[*] Sourcing Intel oneAPI platform flags (Tracking log: ${INTEL_LOG})..."
    
    # Temporarily drop strict flags to ride through loose vendor code variables
    set +u 2>/dev/null
    source "$INTEL_ROOT/setvars.sh" --force > "${INTEL_LOG}" 2>&1
    
    export ONEAPI_ROOT="$INTEL_ROOT"
    export MKLROOT="$INTEL_ROOT/mkl/latest"
    echo "[+] Intel oneAPI environment sourced successfully."
else
    echo "[!] Intel oneAPI setvars.sh not found at $INTEL_ROOT."
fi

# ------------------------------------------------------------------------------
# 7. Set IrisLime Compilation Matrix & Runtime Variables
# ------------------------------------------------------------------------------
#
# Dynamic path configuration matching the upstream Ubuntu 26 package paths

if [ -d "/usr/lib/x86_64-linux-gnu/cmake/openvino" ]; then
    export OpenVINO_DIR="/usr/lib/x86_64-linux-gnu/cmake/openvino"
else
    export OpenVINO_DIR="/usr/lib/cmake/openvino"
fi
export INTEL_OPENVINO_DIR="/usr"

# Hypervisor Layer Override: Route to stable OpenCL framework to prevent Level Zero SIGSEGV
export ONEAPI_DEVICE_SELECTOR="opencl:1"

# Global Node Identity Configurations
export ISLM_USER="${ISLM_USER:-default_node}"

# Centralized Model Target Interpolation
export IRISLIME_MODELS_DIR="../models"
export IRISLIME_TEST_MODEL="${IRISLIME_TEST_MODEL:-$IRISLIME_MODELS_DIR/tinyllama-1.1b-chat-v1.0.Q4_0.gguf}"

# Hardware Acceleration and Debugging Settings
export ZES_ENABLE_SYSMAN=1
export DEBUGINFOD_CACHE_PATH="$HOME/.cache/gdb_symbols"
export TCM_ENABLE=1

# Node.js Version Manager (NVM) Toolchain Initialization
export NVM_DIR="${HOME}/.nvm"
if [[ -s "${NVM_DIR}/nvm.sh" ]]; then
    set +u 2>/dev/null
    source "${NVM_DIR}/nvm.sh"
    nvm use 20 --silent >/dev/null 2>&1 || nvm install 20 --silent >/dev/null 2>&1
    echo "[+] Node.js Toolchain initialized on version: $(node -v 2>/dev/null || echo '20')"
else
    echo "[!] Warning: Node Version Manager missing at ${NVM_DIR}. Native UI generation may hit dependencies."
fi

# RESTORE ORIGINAL VOLATILE SHELL FLAG CONFIGURATIONS
if [ "${_IR_ORIG_SET_U}" -eq 1 ]; then set -u; else set +u; fi
unset _IR_ORIG_SET_U

# ------------------------------------------------------------------------------
# 8. Optimized Interactive Prompt Geometry (Zero-Overhead Hybrid Model)
# ------------------------------------------------------------------------------
#
# Bash magic notes:
# Single quotes freeze the literal text structure at assignment time.
# Bash natively parses the variable expansion and time variables inside its 
# C-core loop on carriage returns with zero subshell forking penalties.

if [[ $- == *i* ]]; then
    export PS1='\[\e]0;\u@\h: \w\a\]\n\[\033[01;32m\]\u@\h\[\033[00m\]:\[\033[01;35m\]${ISLM_RUN_TYPE:+[$ISLM_RUN_TYPE]: }\[\033[00m\]\[\033[01;37m\]\w\[\033[00m\] \[\033[01;33m\]\D{%y%m_%H%M}_\!\[\033[00m\]\n; '
fi

# ------------------------------------------------------------------------------
# 9. Syntactic Sugar / Predictable Shortcut Symmetry
# ------------------------------------------------------------------------------
alias build_runner="uv run tools/build_runner.py"
alias extract_telemetry="uv run tools/extract_telemetry.py"
alias test_runner="uv run tools/test_runner.py"
alias quick_litert="./tools/quick_test_litert.py"
alias files2clip="tools/files2clip"
alias clip2files="tools/clip2files"

alias bbptests_runner="uv run tools/bbptests_runner.py --profile vulkan_debug"
alias bbpsmoke_runner="IRISLIME_FLAG_VARS='SMOKE_HELP' uv run tools/bbptests_runner.py"

# Structured Text I/O Helpers & Aliases
pto() {
    python "${IRISLIME_ROOT}/tools/patch_io.py" out "$@"
}
pti() {
    python "${IRISLIME_ROOT}/tools/patch_io.py" in "$@"
}
alias files2clip="uv run python ${IRISLIME_ROOT}/tools/files2clip"
alias clip2files="uv run python ${IRISLIME_ROOT}/tools/clip2files"
alias pack2clip=pto
alias patch_incoming=pti

# Terminal Dashboard (mtfdash v1.8.6) POSIX / WSL Interop Wrapper
mtfdash() {
    pwsh.exe -NoProfile -ExecutionPolicy Bypass -File 'C:\Users\feker\src\fekerr-dev\ps7\Get-TerminalDashboard.ps1' "$@"
}
alias mtfdash-status="pwsh.exe -NoProfile -ExecutionPolicy Bypass -Command \"& 'C:\\Users\\feker\\src\\fekerr-dev\\ps7\\Get-TerminalDashboard.ps1' -isolate -slot status\""
alias mtfdash-nodes="python3 ${IRISLIME_ROOT}/tools/mtfdash_node_manager.py discover"
alias mtfdash-members="python3 ${IRISLIME_ROOT}/tools/mtfdash_node_manager.py discover"
alias mtfdash-matrix="python3 ${IRISLIME_ROOT}/tools/mtfdash_node_manager.py discover"
alias mtfdash-send="python3 ${IRISLIME_ROOT}/tools/mtfdash_node_manager.py send-cmd"
alias mtfdash-inbox="python3 ${IRISLIME_ROOT}/tools/mtfdash_node_manager.py process-inbox"
alias mtfdash-issue="python3 ${IRISLIME_ROOT}/tools/mtfdash_node_manager.py log-issue"
alias mtfdash-log="python3 ${IRISLIME_ROOT}/tools/mtfdash_node_manager.py log-issue"
alias mtfdash-register="python3 ${IRISLIME_ROOT}/tools/mtfdash_node_manager.py register"
alias mtfdash-rclone="python3 ${IRISLIME_ROOT}/tools/mtfdash_node_manager.py rclone-delegate"
alias agy-mtfdash="python3 ${IRISLIME_ROOT}/tools/agy_mtfdash_bridge.py"
alias llama-mtfdash="python3 ${IRISLIME_ROOT}/tools/llamacpp_mtfdash_bridge.py"

# WSL to Win11 Rclone Bridge
rclone() {
    python3 "${IRISLIME_ROOT}/tools/wsl_rclone_bridge.py" "$@"
}

# Auto-register WSL Node Heartbeat in local disk mesh
python3 "${IRISLIME_ROOT}/tools/mtfdash_node_manager.py" register --narrative "WSL Ubuntu shell session loaded" || true

export IRISLIME_READY=1
echo "[+] IrisLime shared configuration preferences cleanly evaluated."
echo "[+] IrisLime environment is ready."

# ==============================================================================
# Context Boundary: config_env_Complete
# ==============================================================================
