#!/bin/bash
# Filename: config_env
# Purpose: Clean foreign environments and load IrisLime dependencies

# 1. Environment Sweeper: Deactivate any existing venv
if [[ "$VIRTUAL_ENV" != "" ]]; then
    echo "[!] Deactivating foreign environment: $VIRTUAL_ENV"
    # Try to deactivate, fallback to manual unset
    if command -v deactivate >/dev/null; then
        deactivate
    else
        unset VIRTUAL_ENV
    fi
fi

# 2. Setup IrisLime local environment
if [ -d "venv" ]; then
    source venv/bin/activate
    export IRISLIME_ROOT=$(pwd)
    export IRISLIME_READY=true
    echo "[+] IrisLime environment is ready (Root: $IRISLIME_ROOT)."
else
    echo "[!] Error: 'venv' directory not found. Run 'make setup' first."
fi
